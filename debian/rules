#!/usr/bin/make -f
export PYBUILD_NAME=normfn
# Pin the wheel version to the changelog version to avoid dirty-tree false positives.
# dpkg-parsechangelog -S Version returns e.g. "3.0.3-1"; strip the Debian revision.
export SETUPTOOLS_SCM_PRETEND_VERSION = $(shell dpkg-parsechangelog -S Version | sed 's/-[0-9]*$$//')
%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_build:
	uv build --wheel

override_dh_auto_install:
	python3 $(CURDIR)/debian/install-wheel \
		$(CURDIR)/debian/normfn dist/normfn-*.whl
	mkdir -p $(CURDIR)/debian/normfn/usr/share/bash-completion/completions
	mkdir -p $(CURDIR)/debian/normfn/usr/share/zsh/vendor-completions
	uv run python -m shtab --shell bash normfn.args.get_parser \
		> $(CURDIR)/debian/normfn/usr/share/bash-completion/completions/normfn
	uv run python -m shtab --shell zsh normfn.args.get_parser \
		> $(CURDIR)/debian/normfn/usr/share/zsh/vendor-completions/_normfn

override_dh_auto_test:
	uv run pytest
